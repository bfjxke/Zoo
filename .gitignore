# ============================================
# GuardianEye-IIoT 沙箱动物园
# Git忽略配置
# ============================================

# IDE 配置
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
*.swo

# Java 后端
backend/target/
backend/*.log
backend/*.class
backend/.classpath
backend/.project
backend/.settings/

# Python AI调度器
agent/venv/
agent/__pycache__/
agent/*.pyc
agent/.env
agent/pyvenv.cfg

# 前端
frontend/node_modules/
frontend/dist/
frontend/.nuxt/
frontend/.output/

# 构建产物
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# 日志文件
*.log
logs/
*.log.*

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# 临时文件
*.tmp
*.bak
*.swp
*~

# 环境配置文件（包含敏感信息）
.env
*.env.local

# Maven Wrapper
backend/mvnw
backend/mvnw.cmd
backend/.mvn/

# 测试覆盖率报告
coverage/
*.exec
jacoco.exec

# IDE 编译输出
out/
build/
target/test-classes/
target/classes/
target/generated-sources/